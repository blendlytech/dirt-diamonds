        { "id": "half_present", "autopilot_weight": 1, "label": "Play along, phone in hand",
          "consequences": [
            { "type": "stress", "amount": -1 }
          ] },
        { "id": "bail_early", "autopilot_weight": 1, "label": "Bail early, something came up",
          "consequences": [
            { "type": "child_development", "axis": "care", "amount": -2 },
            { "type": "child_development", "axis": "neglect", "amount": 1 }
          ] }
      ]
    },
    {
      "id": "hs_the_hard_conversation",
      "scope": "avatar",
      "weight": 0.03,
      "cooldown_days": 60,
      "contact": "family_kid",
      "category": "family",
      "prompt": "Your kid got in trouble at school today. How you handle tonight's conversation is going to stick with them.",
      "prerequisites": [
        { "flag_active": "hs_has_child" }
      ],
      "choices": [
        { "id": "listen_first", "autopilot_weight": 2, "label": "Listen before you react",
          "consequences": [
            { "type": "child_development", "axis": "care", "amount": 2 },
            { "type": "person_stat", "stat": "maturity", "amount": 2 }
          ] },
        { "id": "lay_down_the_law", "autopilot_weight": 1, "label": "Lay down the law",
          "consequences": [
            { "type": "child_development", "axis": "coaching", "amount": 1 },
            { "type": "child_development", "axis": "care", "amount": -1 },
            { "type": "stress", "amount": 2 }
          ] },
        { "id": "let_it_slide", "autopilot_weight": 1, "label": "Let it slide, you don't have the energy tonight",
          "consequences": [
            { "type": "child_development", "axis": "neglect", "amount": 1 },
            { "type": "child_development", "axis": "care", "amount": -1 }
          ] }
      ]
    },
    {
      "id": "hs_school_calls_about_neglect",
      "scope": "avatar",
      "weight": 0.04,
      "cooldown_days": 45,
      "contact": "family_kid",
      "category": "family",
      "prompt": "The school counselor is on the phone. She's noticed your kid slipping -- grades, mood, somebody picking them up late again and again.",
      "prerequisites": [
        { "flag_active": "hs_child_neglect_pattern", "min_days_since": 14 }
      ],
      "choices": [
        { "id": "take_it_seriously", "autopilot_weight": 2, "label": "Take it seriously, ask what you can do",
          "consequences": [
            { "type": "clear_flag", "flag": "hs_child_neglect_pattern" },
            { "type": "child_development", "axis": "care", "amount": 3 },
            { "type": "child_development", "axis": "neglect", "amount": -3 },
            { "type": "person_stat", "stat": "maturity", "amount": 2 },
            { "type": "stress", "amount": 5 }
          ] },
        { "id": "get_defensive", "autopilot_weight": 1, "label": "Get defensive, it's not that bad",
          "consequences": [
            { "type": "child_development", "axis": "neglect", "amount": 2 },
            { "type": "person_stat", "stat": "morality", "amount": -2 },
            { "type": "stress", "amount": 6 }
          ] },
        { "id": "promise_to_do_better", "autopilot_weight": 1, "label": "Promise to do better and mean it, for now",
          "consequences": [
            { "type": "stress", "amount": 2 }
          ] }
      ]
    },
    {
      "id": "hs_course_correction",
      "scope": "avatar",
      "weight": 0.05,
      "cooldown_days": 30,
      "contact": "family_kid",
      "category": "family",
      "prompt": "You've noticed it too -- the distance building between you and your kid. Tonight's as good a night as any to actually do something about it.",
