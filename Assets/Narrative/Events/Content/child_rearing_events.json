            { "type": "stress", "amount": 2 }
          ] },
        { "id": "make_it_up_this_weekend", "autopilot_weight": 1, "label": "Promise a whole weekend to make up for it",
          "consequences": [
            { "type": "child_development", "axis": "care", "amount": 1 },
            { "type": "stress", "amount": 3 }
          ] }
      ]
    },
    {
