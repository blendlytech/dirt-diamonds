      "choices": [
        { "id": "commit_to_it", "autopilot_weight": 2, "label": "Commit to it, phone off",
          "consequences": [
            { "type": "child_development", "axis": "care", "amount": 2 },
            { "type": "child_development", "axis": "coaching", "amount": 1 },
            { "type": "person_stat", "stat": "happiness", "amount": 2 }
