# Godot 4 generated files
# *.import metadata IS committed (Godot recommendation, Phase 12a): without it a
# stale .godot cache silently drops the theme's fonts and the game renders in
# Godot's default gray theme. The imported binaries stay under .godot/ (ignored).
.godot/
export.cfg
export_credentials.cfg
# export_presets.cfg is deliberately COMMITTED (Phase 11e): in Godot 4 the
# secrets live in export_credentials.cfg above; the presets carry the
# load-bearing .sql/.json include filters and must travel with the repo.

# Export build output (Phase 11e presets write here)
Build/

# .NET build artifacts
.mono/
bin/
obj/
*.user
mono_crash.*.json
data_*/

# SQLite runtime database (schema lives in SchemaDefinitions.sql; the .db is game state)
*.db
*.db-journal
*.db-wal
*.db-shm

# Steamworks native libraries are copied at build time, not committed
steam_api64.dll
libsteam_api.so
steam_appid.txt

# Editor / OS noise
.vs/
.vscode/
.idea/
Thumbs.db
Desktop.ini

# Local Claude settings (machine-specific permissions)
.claude/settings.local.json
